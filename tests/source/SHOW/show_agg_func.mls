LOAD 'data.csv' AS CSV INTO my_dataset;
SHOW MEAN OF "price" FROM my_dataset;
SHOW MAX OF "price" FROM my_dataset;
SHOW MIN OF "price" FROM my_dataset;
SHOW SUM OF "price" FROM my_dataset;
SHOW MEDIAN OF "price" FROM my_dataset;
SHOW PROD OF "price" FROM my_dataset;
SHOW STD OF "price" FROM my_dataset;
SHOW VAR OF "price" FROM my_dataset;
SHOW UNIQUE_VALS OF "price" FROM my_dataset;
SHOW UNIQUE_COUNT OF "price" FROM my_dataset;